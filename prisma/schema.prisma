generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model SmartbillInvoice {
  id           String    @id @default(cuid())
  invoiceKey   String    @unique // e.g. "SSB-476"
  series       String
  number       Int
  client       String    @default("")
  totalAmount  Float
  paidAmount   Float
  unpaidAmount Float
  paid         Boolean
  netAmount    Float
  taxAmount    Float
  issuedAt     DateTime
  dueDate      DateTime?
  syncedAt     DateTime  @default(now())
}

model SmartbillClient {
  id          String  @id @default(cuid())
  name        String  @unique
  cif         String  @default("")
  clientCode  String  @default("")
  phone       String  @default("")
  email       String  @default("")
  contact     String  @default("")
}

model SmartbillSyncState {
  series            String @id
  lastSyncedNumber  Int
  nextNumber        Int
  updatedAt         DateTime @updatedAt
}

// Facebook Ads cache — one row per (level, entityId, date)
model FacebookAdInsight {
  id              String   @id @default(cuid())
  level           String   // "campaign" | "adset" | "ad"
  entityId        String   // campaign_id / adset_id / ad_id
  entityName      String
  campaignId      String?
  campaignName    String?
  adsetId         String?
  adsetName       String?
  status          String?
  objective       String?
  dateStart       DateTime
  dateStop        DateTime
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  spend           Float    @default(0)
  reach           Int      @default(0)
  frequency       Float    @default(0)
  ctr             Float    @default(0)   // click-through rate %
  cpc             Float    @default(0)   // cost per click
  cpm             Float    @default(0)   // cost per 1000 impressions
  cpp             Float    @default(0)   // cost per result (purchase)
  purchaseRoas    Float?                 // ROAS from purchase conversion
  conversions     Int      @default(0)
  costPerConversion Float  @default(0)
  budget          Float?                 // daily or lifetime budget
  budgetType      String?                // "daily" | "lifetime"
  accountId       String
  syncedAt        DateTime @default(now())

  @@unique([level, entityId, dateStart, dateStop])
  @@index([level, dateStart, dateStop])
}

model CrmCall {
  id              String   @id @default(cuid())
  invoxId         String   @unique
  caller          String
  account         String?
  date            DateTime
  duration        String?
  status          String?
  source          String?
  campaign        String?
  utmSource       String?
  medium          String?
  receivingNumber String?
  recordingUri    String?
  reason          String?
  summary         String?
  rawPayload      Json?
  createdAt       DateTime @default(now())
}
